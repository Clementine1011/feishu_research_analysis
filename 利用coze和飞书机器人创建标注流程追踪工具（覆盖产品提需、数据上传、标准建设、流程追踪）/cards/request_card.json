{
  "name": "request_card",
  "dsl": {
    "schema": "2.0",
    "header": {
      "title": { "tag": "plain_text", "content": "产品提需阶段" },
      "template": "blue"
    },
    "body": {
      "elements": [
        {
          "tag": "markdown",
          "content": "**产品提需阶段提醒**：请确认需求信息并完成提报。"
        },
        {
          "tag": "column_set",
          "columns": [
            {
              "tag": "column",
              "elements": [
                { "tag": "markdown", "content": "**需求编号：** {{需求编号}}" },
                { "tag": "markdown", "content": "**标题：** {{标题}}" },
                { "tag": "markdown", "content": "**所属产品/场景：** {{所属产品场景}}" }
              ]
            },
            {
              "tag": "column",
              "elements": [
                { "tag": "markdown", "content": "**优先级：** {{优先级}}" },
                { "tag": "markdown", "content": "**期望上线时间：** {{期望上线时间}}" },
                { "tag": "markdown", "content": "**SLA（天）：** {{SLA}}" }
              ]
            }
          ]
        },
        {
          "tag": "markdown",
          "content": "在多维表中查看详情并更新状态。"
        },
        {
          "tag": "button",
          "text": { "tag": "plain_text", "content": "打开需求视图" },
          "type": "primary",
          "behaviors": [
            {
              "type": "open_url",
              "default_url": "https://bytedance.larkoffice.com/base/DQE2bkPVba3cI5sh30ocyGh8ngh?table=tbl80c6U7FSZDnBx&view=vew8Qso4ai"
            }
          ]
        }
      ]
    }
  }
}
